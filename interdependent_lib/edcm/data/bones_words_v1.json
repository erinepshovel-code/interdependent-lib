    "read_mode_v1": "Count by primary field only.",
    "read_mode_v1.1": "Count by families array. Consumer decides weighting.",
    "hmmm": [
      "existential vs spatial there",
      "relative vs interrogative who/which",
      "conditional if: K or T",
      "interjections beyond yes/no",
      "so/too as degree adverb vs structural connector — context-dependent, bone only in connector use",
      "multi-word units need tokenizer support"
    ],
    "multiword_join_rule": {
      "status": "always-on",
      "convention": "smash (no underscores, no spaces). 'of course' → 'ofcourse'",
      "placement": "applied in normalize.py BEFORE tokenization and bone matching",
      "ordering": "longest-match-first to prevent partial joins",
